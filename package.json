{
  "name": "worthycode",
  "displayName": "WorthyCode",
  "description": "Track your coding cost - convert dev time to money",
  "version": "0.1.0",
  "publisher": "riroan",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "worthycode",
          "title": "WorthyCode",
          "icon": "$(credit-card)"
        }
      ]
    },
    "views": {
      "worthycode": [
        {
          "id": "worthycode.settings",
          "name": "Settings"
        },
        {
          "id": "worthycode.stats",
          "name": "Today's Stats"
        }
      ]
    },
    "commands": [
      {
        "command": "worthycode.showDashboard",
        "title": "WorthyCode: Show Dashboard"
      },
      {
        "command": "worthycode.resetToday",
        "title": "WorthyCode: Reset Today"
      },
      {
        "command": "worthycode.toggleTracking",
        "title": "WorthyCode: Toggle Tracking"
      }
    ],
    "configuration": {
      "title": "WorthyCode",
      "properties": {
        "worthycode.hourlyRate": {
          "type": "number",
          "default": 30000,
          "description": "Hourly rate"
        },
        "worthycode.idleTimeout": {
          "type": "number",
          "default": 60,
          "description": "Idle timeout (seconds)"
        },
        "worthycode.currency": {
          "type": "string",
          "default": "$",
          "description": "Currency symbol"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  }
}
